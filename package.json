{
  "name": "children-of-gaza",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A memorial field of shoes — one pair for each child killed in Gaza.",
  "scripts": {
    "build-data": "tsx scripts/build-dataset.ts",
    "build-og": "tsx scripts/build-og.ts",
    "dev": "vite",
    "build": "pnpm run build-data && pnpm run build-og && vite build",
    "preview": "pnpm run build && wrangler dev",
    "typecheck": "tsc --noEmit",
    "deploy": "pnpm run build && wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.0",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.6.0",
    "@types/three": "^0.184.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "wrangler": "^4.102.0"
  },
  "dependencies": {
    "three": "^0.184.0"
  }
}
